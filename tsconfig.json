{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "baseUrl": ".",
      "paths": {
        "@/*": ["./src/*"],
            "@assets/*": ["./src/assets/*"],
            "@screens/*": ["./src/screens/*"],
            "@services/*": ["./src/services/*"],
            "@components/*": ["./src/components/*"], 
            "@types/*": ["./src/types/*"],
            "@utils/*": ["./src/utils/*"],
      }
